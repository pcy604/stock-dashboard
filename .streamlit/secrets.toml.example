# Streamlit Cloud 배포 시 사용할 비밀키 템플릿
# ─────────────────────────────────────────────
# 이 파일은 '예시'다. 실제 값은 절대 여기 적지 말고,
# Streamlit Cloud 대시보드의 Settings → Secrets 에 같은 형식으로 붙여넣는다.
# (로컬에서 secrets로 테스트하려면 이 파일을 secrets.toml 로 복사 후 값 채우기 — gitignore됨)

FRED_KEY = "여기에_FRED_API_키"

# 선택 — 텔레그램 알림을 클라우드에서도 보내려면
TELEGRAM_TOKEN = "여기에_텔레그램_봇토큰"
TELEGRAM_CHAT_ID = "여기에_챗ID"

